# Next.js (client-exposed) configuration
# These values are bundled into the client; do not treat them as secrets.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Demo-only admin credentials (client-exposed; for real security, do this server-side)
NEXT_PUBLIC_ADMIN_USER=
NEXT_PUBLIC_ADMIN_PASS=

# Python scripts (server-side; keep these secret)
SUPABASE_DB_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# Admin server session (recommended)
ADMIN_USER=
ADMIN_PASS=
ADMIN_SESSION_SECRET=
